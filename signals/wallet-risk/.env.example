# X Layer Testnet (chainId 195) — defaults
CHAIN_ID=195

# Signal operator: EOA with OKB for gas (get from X Layer testnet faucet)
SIGNAL_PRIVATE_KEY=0x...
PAY_TO=0x...

# Price per call in token base units (6 decimals). 1000 = 0.001 bUSD
PRICE=1000
PORT=4001

# Settlement token — after deploying TestToken, fill these from deployments/xlayerTestnet.testtoken.json
TOKEN_ADDRESS=0x...
TOKEN_NAME=Beacon USD
TOKEN_VERSION=1
TOKEN_SYMBOL=bUSD
