{
  "name": "@beacon/sdk",
  "version": "1.0.0",
  "description": "Beacon Signal SDK — define composable, x402-priced signals with cryptographic cascade receipts. First-class X Layer support.",
  "keywords": [
    "x402",
    "xlayer",
    "x-layer",
    "onchain-os",
    "okx",
    "agent",
    "signal",
    "cascade",
    "eip-712",
    "eip-3009"
  ],
  "author": "Beacon Protocol",
  "license": "MIT",
  "homepage": "https://beacon.gudman.xyz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ridwannurudeen/beacon.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/Ridwannurudeen/beacon/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@x402/core": "^2.9.0",
    "@x402/evm": "^2.9.0",
    "@x402/extensions": "^2.9.0",
    "@x402/fetch": "^2.9.0",
    "hono": "^4.6.0",
    "viem": "^2.21.0",
    "x402": "^1.1.0",
    "x402-fetch": "^1.1.0",
    "x402-hono": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
