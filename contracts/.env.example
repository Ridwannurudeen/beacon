# Private key that deploys contracts and publishes signals. Needs OKB for gas on X Layer.
PRIVATE_KEY=0x...

# RPC overrides (defaults are fine).
XLAYER_RPC=https://rpc.xlayer.tech
XLAYER_TESTNET_RPC=https://testrpc.xlayer.tech

# OKLink Explorer API key for contract verification (optional).
OKLINK_API_KEY=

# Signal URLs — override when deploying to production hosts.
WALLET_RISK_URL=https://wallet-risk.beacon.fyi/signal
LIQUIDITY_DEPTH_URL=https://liquidity-depth.beacon.fyi/signal
YIELD_SCORE_URL=https://yield-score.beacon.fyi/signal
SAFE_YIELD_URL=https://safe-yield.beacon.fyi/signal

# Demo traffic config.
ITERATIONS=500
DEMO_PAYER=0x...
